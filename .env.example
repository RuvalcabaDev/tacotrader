# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# iTick API Configuration
ITICK_API_KEY=your_itick_api_key_here
ITICK_API_BASE_URL=https://api.itick.org

# BMV Market Hours (Ciudad de México) - Horario extendido
BMV_MARKET_OPEN_CDMX=07:00
BMV_MARKET_CLOSE_CDMX=15:00
BMV_SCRAPE_INTERVAL_MINUTES=5

# Screener Configuration
BMV_MAX_SYMBOLS=100
BMV_MIN_MOVEMENT_PERCENT=2.0
BMV_MIN_REL_VOLUME=1.8
BMV_MIN_ATR_PERCENT=2.5
BMV_MIN_MARKET_CAP_MXN=10000000000  # $10B MXN
BMV_MIN_PRICE_MXN=10.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Cache Configuration
CACHE_TTL_MINUTES=5
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2
